                </div>
                <div>
                    <label>MARGIN INTEREST RATE (%)</label>
                    <input type="number" id="gmInterest" value="5" onchange="sim.settings.interestRate = this.value / 100">
                </div>
            </div>

            <div class="control-panel" style="border-color:var(--neon-green);">
                <h3 style="color:var(--neon-green); margin:0; grid-column:1/-1;">CORPORATE OVERSIGHT (EDIT / REMOVE)</h3>
