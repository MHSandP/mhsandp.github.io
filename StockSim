                <div><label>NAME</label><input type="text" id="editName"></div>
                <div><label>PRICE (¥)</label><input type="number" id="editPrice"></div>
                <div><label>TOTAL SHARES</label><input type="number" id="editTotal"></div>
                <div><label>OWNED %</label><input type="number" id="editOwned"></div>
                <div style="display:flex; align-items:center;">
                    <label style="width:auto; margin-right:10px;">PRIVATE?</label>
                    <input type="checkbox" id="editPrivate" style="width:auto;">
                </div>
                <div style="grid-column:1/-1; display:flex; gap:10px;">
                    <button onclick="sim.saveEditCorp()" style="flex:1;">SAVE CHANGES</button>
                    <button onclick="sim.deleteCorp()" style="flex:1; border-color:var(--neon-red); color:var(--neon-red);">DELETE CORP</button>
                </div>
            </div>

            <div class="control-panel" style="border-color: var(--neon-blue);">
                <h3 style="color:var(--neon-blue); margin:0; grid-column:1/-1;">IPO LAUNCHPAD (ADD CORP)</h3>
                <div><label>SYMBOL</label><input type="text" id="ipoSym" placeholder="ABCD"></div>
                <div><label>NAME</label><input type="text" id="ipoName" placeholder="Corporation Name"></div>
                <div><label>PRICE</label><input type="number" id="ipoPrice" value="100"></div>
                <div><label>TOTAL SHARES</label><input type="number" id="ipoTotal" value="10000000"></div>
                <div><label>OWNED %</label><input type="number" id="ipoOwned" value="50"></div>
                <div style="display:flex; align-items:center;">
                    <label style="width:auto; margin-right:10px;">PRIVATE?</label>
                    <input type="checkbox" id="ipoPrivate" style="width:auto;">
                </div>
                <button onclick="sim.addCorp()" style="grid-column:1/-1;">LAUNCH NEW STOCK</button>
            </div>

            <div class="control-panel" style="border-color:var(--neon-amber);">
                <h3 style="color:var(--neon-amber); margin:0;">GM OVERRIDE</h3>
                <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:10px;">
                    <button onclick="sim.triggerEvent('crash')">📉 CRASH</button>
                    <button onclick="sim.triggerEvent('boom')">📈 BOOM</button>
                    <button onclick="sim.triggerEvent('magic')">✨ MANA</button>
                    <button onclick="sim.timeSkip()">⏩ SKIP WEEK</button>
                </div>
            </div>

            <div class="card">
                <h4>PLAYER AUDIT</h4>
                <table id="auditTable">
                    <thead><tr><th>NAME</th><th>CASH</th><th>DEBT</th><th>NET WORTH</th></tr></thead>
                    <tbody id="auditBody"></tbody>
                </table>
            </div>

            <div class="control-panel" style="margin-top:20px;">
                <h4 style="margin:0 0 10px 0;">DATA MANAGEMENT</h4>
                <div style="display:flex; gap:10px;">
                    <button onclick="sim.exportData()">💾 SAVE</button>
                    <input type="file" id="importFile" style="width:auto;">
                    <button onclick="sim.importData()">📂 LOAD</button>
                    <button onclick="sim.reset()">❌ WIPE</button>
                </div>
            </div>
            
            <div style="margin-top:20px;">
                <h4>NEW IDENTITY</h4>
                <input type="text" id="newPName" placeholder="Handle" style="width:200px;">
                <input type="number" id="newPCash" value="100000" style="width:150px;">
                <button onclick="sim.addPlayer()" style="width:auto;">CREATE</button>
            </div>
        </div>
    </div>

