            init: function() {
                this.stocks.forEach(s => {
                    s.float = s.private ? 0 : s.total * (1 - (s.owned / 100));
                    if(!s.history || s.history.length === 0) {
                        s.history = [];
                        for(let i=0; i<30; i++) s.history.push(s.price);
                    }
                });
                this.start();
                this.renderAll();
            },

            start: function() {
                if(this.interval) clearInterval(this.interval);
                this.interval = setInterval(() => {
                    if(this.settings.active) {
                        this.stocks.forEach(s => this.math(s));
                        this.renderAll();
                    }
                }, this.settings.speed);
            },

            math: function(s) {
                if(s.private) return; 
                const liquidity = s.float / s.total; 
                const scarcity = 1 + (1 - liquidity); 
                const dir = (Math.random() - 0.49) * 2; 
                const drift = 0.0005; 
                
                let reversion = 0;
                if (s.price < (s.basePrice * 0.7)) {
                    reversion = (s.basePrice - s.price) * 0.002;
                }

                const change = (s.price * 0.01) * dir * s.vol * scarcity;
                s.price += (change + (s.price * drift) + reversion);
                
                if(s.price < 0.01) s.price = 0.01;
                
                s.history.push(s.price);
                if(s.history.length > 50) s.history.shift();
            },

            trade: function(type) {
                const pIdx = document.getElementById('playerSelect').value;
                const sym = document.getElementById('stockSelect').value;
                const amt = parseInt(document.getElementById('tradeAmt').value);
                
                if(pIdx === "Select Identity..." || sym === "Select Asset..." || !amt || amt <= 0) return alert("Invalid Order");
                
                const p = this.players[pIdx];
                const s = this.stocks.find(i => i.sym === sym);
                const cost = s.price * amt;

                if(s.private) return alert("ERROR: Asset is PRIVATE.");
                if(!p.portfolio[sym]) p.portfolio[sym] = { shares: 0, avgCost: 0 };

                if(type === 'buy') {
                    if(amt > s.float) return alert("Insufficient Liquidity");
                    if(p.cash < cost) return alert("Insufficient Funds");
                    
                    const curS = p.portfolio[sym].shares;
                    const curT = curS * p.portfolio[sym].avgCost;
                    p.portfolio[sym].avgCost = (curT + cost) / (curS + amt);
                    
                    p.cash -= cost;
                    p.portfolio[sym].shares += amt;
                    s.float -= amt;
                    this.log(p.name, `BOUGHT ${amt} ${sym}`);
                } else if(type === 'sell') {
                    if(p.portfolio[sym].shares < amt) return alert("Insufficient Shares");
                    
                    let revenue = cost;
                    if (p.debt > 0) {
                        if (revenue >= p.debt) {
                            revenue -= p.debt;
                            this.log(p.name, `PAID OFF DEBT: ¥${p.debt.toLocaleString()}`);
                            p.debt = 0;
                        } else {
                            p.debt -= revenue;
                            this.log(p.name, `REDUCED DEBT BY: ¥${revenue.toLocaleString()}`);
                            revenue = 0;
                        }
                    }
                    
                    p.cash += revenue;
                    p.portfolio[sym].shares -= amt;
                    s.float += amt;
                    this.log(p.name, `SOLD ${amt} ${sym}`);
                } else if(type === 'margin_buy') {
                    if(amt > s.float) return alert("Insufficient Liquidity");
                    p.debt += cost; 
                    const curS = p.portfolio[sym].shares;
                    const curT = curS * p.portfolio[sym].avgCost;
                    p.portfolio[sym].avgCost = (curT + cost) / (curS + amt);
                    p.portfolio[sym].shares += amt; 
                    s.float -= amt;
                    this.log(p.name, `MARGIN BUY ${amt} ${sym}`);
                } else if(type === 'short') {
                    p.cash += cost; 
                    p.portfolio[sym].shares -= amt;
                    this.log(p.name, `SHORT SOLD ${amt} ${sym}`);
                }
                
                const impact = (amt / s.total) * 0.5; 
                if(type.includes('buy')) s.price *= (1 + impact);
                else s.price *= (1 - impact);
                
                this.renderAll();
            },

