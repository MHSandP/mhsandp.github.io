<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zurich Orbital // Market Sim v9.1</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');
        
        :root {
            --neon-green: #00ff41;
            --neon-pink: #ff0080;
            --neon-blue: #00f3ff;
            --neon-amber: #ff9900;
            --neon-red: #ff0000;
            --dark-bg: #050505;
            --panel-bg: rgba(10, 15, 20, 0.95);
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--dark-bg);
            color: var(--neon-green);
            font-family: 'Share Tech Mono', monospace;
            margin: 0; padding: 0;
            overflow-x: hidden;
            background-image: 
                linear-gradient(rgba(0, 255, 65, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 255, 65, 0.05) 1px, transparent 1px);
            background-size: 30px 30px;
            padding-bottom: 50px;
        }

        #boot-sequence {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #000; z-index: 9999;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            font-family: 'Orbitron', monospace;
            transition: opacity 1s;
        }
        .boot-text { font-size: 1.5rem; color: var(--neon-green); margin-bottom: 20px; text-shadow: 0 0 10px var(--neon-green); }
        .progress-bar { width: 300px; height: 4px; background: #333; position: relative; }
        .progress-fill { height: 100%; background: var(--neon-green); width: 0%; transition: width 0.1s; box-shadow: 0 0 10px var(--neon-green); }

        .ticker-wrap {
            position: fixed; top: 0; width: 100%; overflow: hidden; height: 30px;
            background-color: #000; border-bottom: 1px solid var(--neon-green);
            white-space: nowrap; z-index: 100;
        }
        .ticker { display: inline-block; margin-top: 5px; animation: ticker 60s linear infinite; }
        .ticker-item { display: inline-block; padding: 0 2rem; font-size: 0.9rem; color: var(--neon-green); }
        @keyframes ticker { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-50%, 0, 0); } }

        .container { max-width: 1600px; margin: 60px auto 0 auto; padding: 20px; display: none; opacity: 0; transition: opacity 1s; }
        .visible { display: block !important; opacity: 1 !important; }
        
        .header-bar {
            display: flex; justify-content: space-between; align-items: flex-end;
            border-bottom: 2px solid var(--neon-green); padding-bottom: 10px; margin-bottom: 20px;
        }
        h1 { margin: 0; font-family: 'Orbitron', sans-serif; text-transform: uppercase; color: #fff; text-shadow: 0 0 10px var(--neon-green); }

        .tabs { display: flex; margin-bottom: 0; border-bottom: 1px solid var(--neon-green); }
        .tab-btn {
            background: rgba(0,20,0,0.8); color: #888; border: 1px solid #333; border-bottom: none;
            padding: 15px 25px; cursor: pointer; font-family: 'Orbitron'; margin-right: 5px; transition: 0.3s;
        }
        .tab-btn:hover { background: #111; color: var(--neon-green); }
        .tab-btn.active { background: var(--neon-green); color: #000; font-weight: bold; box-shadow: 0 -5px 15px rgba(0,255,65,0.2); }

        .tab-content { display: none; background: var(--panel-bg); border: 1px solid var(--neon-green); border-top: none; padding: 20px; min-height: 500px; }
        .tab-content.active { display: block; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th { text-align: left; background: rgba(0, 255, 65, 0.1); padding: 12px; color: #fff; font-family: 'Orbitron'; font-size: 0.8em; }
        td { padding: 10px 12px; border-bottom: 1px solid #333; font-size: 0.9em; }
        tr:hover { background: rgba(0, 255, 65, 0.05); }

        .up { color: var(--neon-green); }
        .down { color: var(--neon-pink); }
        .private-lock { color: #555; font-style: italic; }
        
        input, select, button { background: #000; color: var(--neon-green); border: 1px solid var(--neon-green); padding: 8px; font-family: 'Share Tech Mono'; font-size: 0.9em; width: 100%; box-sizing: border-box; }
        button { cursor: pointer; font-weight: bold; text-transform: uppercase; transition: 0.2s; width: auto; }
        button:hover { background: var(--neon-green); color: #000; }
        
        .control-panel { background: rgba(0,0,0,0.5); border: 1px solid #333; padding: 15px; margin-bottom: 20px; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }

        .trade-grid { display: grid; grid-template-columns: 350px 1fr; gap: 20px; }
        .wallet-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 15px; }
        
        .card { background: #050505; border: 1px solid #333; padding: 15px; }
        .card-header { border-bottom: 1px solid #333; margin-bottom: 10px; padding-bottom: 5px; display:flex; justify-content:space-between; }
        
        .stat-row { display: flex; justify-content: space-between; margin-bottom: 5px; font-size: 0.9em; }
        .stat-label { color: #666; }
        .stat-val { color: #fff; }

        .log-box { height: 200px; overflow-y: auto; background: #000; border: 1px solid #333; padding: 10px; font-size: 0.8em; font-family: monospace; }
        .log-entry { margin-bottom: 4px; border-left: 2px solid #333; padding-left: 5px; }

        .btn-buy { border-color: var(--neon-green); color: var(--neon-green); }
        .btn-buy:hover { background: var(--neon-green); color: #000; }
        .btn-sell { border-color: var(--neon-pink); color: var(--neon-pink); }
        .btn-sell:hover { background: var(--neon-pink); color: #000; }
        .btn-short { border-color: var(--neon-amber); color: var(--neon-amber); }
        .btn-short:hover { background: var(--neon-amber); color: #000; }
    </style>
</head>
<body>

    <div id="boot-sequence">
        <div class="boot-text" id="boot-text">ESTABLISHING CONNECTION...</div>
        <div class="progress-bar"><div class="progress-fill" id="boot-fill"></div></div>
    </div>

    <div class="ticker-wrap"><div class="ticker" id="scrollingTicker"></div></div>

    <div class="container" id="main-interface">
        <div class="header-bar">
            <div>
                <h1>Zurich Orbital</h1>
                <div style="font-size: 0.8em; letter-spacing: 2px; color: #666;">MARKET SIM v9.1 // JACKED IN</div>
            </div>
            <div style="text-align: right;">
                <div id="marketStatus" style="color: var(--neon-green); font-weight: bold;">MARKET OPEN</div>
                <div id="nextUpdate" style="font-size: 0.8em; color: #666;">TICK RATE: 5s</div>
            </div>
        </div>

        <div class="tabs">
            <div class="tab-btn active" onclick="sim.tab('market', this)">MARKET DATA</div>
            <div class="tab-btn" onclick="sim.tab('trade', this)">TRADING FLOOR</div>
            <div class="tab-btn" onclick="sim.tab('charts', this)">ANALYTICS</div>
            <div class="tab-btn" onclick="sim.tab('gm', this)">GM TOOLS</div>
        </div>

        <div id="tab-market" class="tab-content active">
            <div class="control-panel">
                <button onclick="sim.togglePause()">PAUSE / RESUME</button>
                <div><label>SPEED:</label><select id="speedSelect" onchange="sim.setSpeed(this.value)"><option value="5000">NORMAL (5s)</option><option value="1000">TURBO (1s)</option></select></div>
            </div>
            <table id="stockTable">
                <thead><tr><th>SYMB</th><th>CORPORATION</th><th>PRICE (¥)</th><th>CHANGE</th><th>OWNED %</th><th>AVAIL FLOAT</th><th>STATUS</th></tr></thead>
                <tbody id="stockTableBody"></tbody>
            </table>
        </div>

        <div id="tab-trade" class="tab-content">
            <div class="control-panel">
                <button onclick="sim.togglePause()" style="grid-column:1/-1;">PAUSE / RESUME SIMULATION</button>
            </div>
            <div class="trade-grid">
                <div class="card" style="border-color: var(--neon-blue);">
                    <h3 style="color:var(--neon-blue); margin-top:0;">COMMLINK TRADE</h3>
                    <div style="margin-bottom:15px;">
                        <label>ACTIVE IDENTITY</label>
                        <select id="playerSelect" onchange="sim.updateUI()"><option>Select Identity...</option></select>
                    </div>
                    <div style="margin-bottom:15px;">
                        <label>ASSET</label>
                        <select id="stockSelect" onchange="sim.updateQuote()"><option>Select Asset...</option></select>
                    </div>
                    <div id="quoteBox" style="background:#000; padding:10px; margin-bottom:15px; border:1px dashed #444; display:none;">
                        <div class="stat-row"><span class="stat-label">PRICE:</span> <span class="stat-val" id="qPrice">--</span></div>
                        <div class="stat-row"><span class="stat-label">FLOAT:</span> <span class="stat-val" id="qFloat">--</span></div>
                        <div class="stat-row"><span class="stat-label">OWNED:</span> <span class="stat-val" id="qOwned">--</span></div>
                        <div class="stat-row"><span class="stat-label">POSITION:</span> <span class="stat-val" id="qPos">--</span></div>
                    </div>
                    <div style="margin-bottom:10px;">
                        <label>AMOUNT (SHARES)</label>
                        <input type="number" id="tradeAmt" placeholder="0">
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:5px; margin-bottom:5px;">
                        <button class="btn-buy" onclick="sim.trade('buy')">BUY</button>
                        <button class="btn-sell" onclick="sim.trade('sell')">SELL</button>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:5px;">
                        <button class="btn-buy" style="border-style:dashed;" onclick="sim.trade('margin_buy')">MARGIN BUY (DEBT)</button>
                        <button class="btn-short" onclick="sim.trade('short')">SHORT SELL</button>
                    </div>
                    <div style="font-size:0.7em; color:#666; margin-top:5px; text-align:center;">*Note: Selling assets auto-pays existing margin debt.</div>
                </div>

                <div>
                    <div id="walletGrid" class="wallet-grid"></div>
                    <div class="card" style="margin-top:20px;">
                        <h4>TRANSACTION LOG</h4>
                        <div id="transLog" class="log-box"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-charts" class="tab-content">
