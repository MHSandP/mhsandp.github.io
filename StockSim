            renderTable: function() {
                const tb = document.getElementById('stockTableBody'); 
                if(!tb) return;
                tb.innerHTML = '';
                this.stocks.forEach(s => {
                    const prev = s.history[s.history.length-2] || s.price;
                    const diff = s.price - prev;
                    const css = diff >= 0 ? 'up' : 'down';
                    const status = s.private ? '<span class="private-lock">🔒 PRIVATE</span>' : 'OPEN';
                    tb.innerHTML += `<tr><td style="color:var(--neon-blue); font-weight:bold;">${s.sym}</td><td>${s.name}</td><td>¥${s.price.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2})}</td><td class="${css}">${diff>=0?'+':''}${diff.toFixed(2)}</td><td>${s.owned}%</td><td>${s.private?'0':s.float.toLocaleString()}</td><td>${status}</td></tr>`;
                });
            },

            renderWallets: function() {
                const grid = document.getElementById('walletGrid'); 
                if(!grid) return;
                grid.innerHTML = '';
                this.players.forEach(p => {
                    let holdings = ''; let assetsVal = 0;
                    for(const [sym, data] of Object.entries(p.portfolio)) {
                        if(data.shares !== 0) {
                            const s = this.stocks.find(i => i.sym === sym);
                            if (s) {
                                const val = data.shares * s.price;
                                assetsVal += val;
                                const roi = data.avgCost>0 ? ((s.price-data.avgCost)/data.avgCost)*100 : 0;
                                holdings += `<div style="border-top:1px dashed #333; font-size:0.8em; margin-top:5px;"><div style="display:flex; justify-content:space-between;"><span style="color:var(--neon-blue)">${sym}</span><span>${data.shares.toLocaleString()} sh</span></div><div style="color:#888;">Avg: ¥${data.avgCost.toFixed(0)} <span style="color:${roi>=0?'var(--neon-green)':'var(--neon-pink)'}">${roi.toFixed(1)}%</span></div></div>`;
                            }
                        }
                    }
                    const nw = p.cash + assetsVal - p.debt;
                    grid.innerHTML += `<div class="card"><div class="card-header"><span>${p.name}</span><span style="color:${nw>=0?'#fff':'var(--neon-red)'}">NW: ¥${nw.toLocaleString(undefined, {maximumFractionDigits:0})}</span></div><div class="stat-row"><span class="stat-label">CASH:</span><span>¥${p.cash.toLocaleString(undefined, {maximumFractionDigits:0})}</span></div><div class="stat-row"><span class="stat-label">DEBT:</span><span style="color:var(--neon-red)">¥${p.debt.toLocaleString(undefined, {maximumFractionDigits:0})}</span></div>${holdings}</div>`;
